# Public HTTPS URL where this addon is reachable (Cloudflare Tunnel hostname).
# Nuvio's player fetches subtitle files from this URL directly, so it must be
# reachable from every device you run Nuvio on.
PUBLIC_URL=https://nuvio-subs.yourdomain.com

# Password for the /admin page (list/delete users). Leave unset to disable
# the admin page entirely (it will 404).
ADMIN_PASSWORD=
